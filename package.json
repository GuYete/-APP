{
  "name": "heimajizhang",
  "version": "1.0.0",
  "description": "黑马记账 - 简洁易用的个人记账应用",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "preview": "node scripts/build.mjs --preview",
    "package:win": "node scripts/build.mjs && npx electron-builder --win",
    "package:mac": "node scripts/build.mjs && npx electron-builder --mac"
  },
  "dependencies": {
    "dexie": "^4.0.8",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.1",
    "jspdf": "^4.2.1",
    "pinia": "^2.2.6",
    "tesseract.js": "^5.1.1",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.4.5",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.heimajizhang.app",
    "productName": "黑马记账",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "sign": null
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "portable": {
      "artifactName": "黑马记账_v${version}.exe"
    },
    "forceCodeSigning": false
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vue-tsc": "^2.1.10"
  }
}
